{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildPlan": "php-22",
    "override": {
      "install": "rm -f package-lock.json && rm -rf node_modules && composer install --optimize-autoloader --no-dev && npm install --ignore-scripts && npm run build"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "releaseCommand": "php artisan migrate --force"
  }
}

